{
  "name": "@kmate/frontend",
  "version": "1.0.0",
  "private": true,
  "description": "K-MATE Frontend Application",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "clean": "rm -rf .next",
    "preview": "npx @opennextjs/cloudflare build && npx @opennextjs/cloudflare preview",
    "deploy": "npx @opennextjs/cloudflare build && npx @opennextjs/cloudflare deploy",
    "upload": "npx @opennextjs/cloudflare build && npx @opennextjs/cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "@ant-design/nextjs-registry": "^1.0.0",
    "@hookform/resolvers": "^3.3.3",
    "@tanstack/react-query": "^5.17.0",
    "antd": "^5.13.0",
    "axios": "^1.6.5",
    "dayjs": "^1.11.10",
    "framer-motion": "^10.18.0",
    "next": "16.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "react-simply-carousel": "^10.0.1",
    "socket.io-client": "^4.6.1",
    "video.js": "^8.6.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/line-clamp": "^0.4.4",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.47",
    "@types/react-dom": "^18.2.18",
    "@types/video.js": "^7.3.58",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.1.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "wrangler": "^4.95.0"
  }
}